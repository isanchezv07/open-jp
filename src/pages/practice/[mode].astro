---
import Layout from '../../layouts/Layout.astro';
import PracticeSession from '../../components/Practice/PracticeSession';

export function getStaticPaths() {
  return [
    { params: { mode: 'ja-es' } },
    { params: { mode: 'es-ja' } },
    { params: { mode: 'audio' } },
    { params: { mode: 'image' } },
    { params: { mode: 'flashcard' } },
  ];
}

const { mode } = Astro.params;
---

<Layout title={`Practicar: ${mode}`}>
  <main class="py-12">
    <PracticeSession mode={mode as any} client:only="react" />
  </main>
</Layout>
