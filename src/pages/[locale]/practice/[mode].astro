---
import Layout from '@/layouts/Layout.astro';
import PracticeSession from '@/components/Practice/PracticeSession';

export function getStaticPaths() {
  const locales = ['es', 'en'];
  const modes = ['ja-es', 'es-ja', 'audio', 'image', 'flashcard'];
  const paths = [];
  for (const locale of locales) {
    for (const mode of modes) {
      paths.push({ params: { locale, mode } });
    }
  }
  return paths;
}

const { mode } = Astro.params;
---

<Layout title={`Practicar: ${mode}`}>
  <main class="py-12">
    <PracticeSession mode={mode as any} client:only="react" />
  </main>
</Layout>
