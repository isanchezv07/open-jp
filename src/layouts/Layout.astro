---
import { seedDatabase } from '../lib/db/seed';
import '../styles/global.css';
import Footer from '../components/Common/Footer.astro';
import SEO from '../components/Common/SEO.astro';
import ThemeToggle from '../components/Common/ThemeToggle';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import LanguagePicker from '../components/Common/LanguagePicker.astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { title, description, image } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const seoDescription = description || t('site.description');
---

<!doctype html>
<html lang={lang}>
	<head>
		<SEO title={title} description={seoDescription} image={image} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,200..1000;1,200..1000&display=swap" rel="stylesheet">
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
	</head>
	<body class="bg-white dark:bg-slate-900 text-slate-800 dark:text-slate-100 font-['Nunito'] min-h-screen flex flex-col transition-colors duration-200">
    <nav class="border-b-2 border-slate-100 dark:border-slate-800 p-4 sticky top-0 bg-white dark:bg-slate-900 z-50 transition-colors duration-200">
      <div class="max-w-4xl mx-auto flex justify-between items-center">
        <a href={`/${lang}`} class="text-3xl font-black text-sky-500 tracking-tighter hover:opacity-80 transition-opacity">
          {t('nav.title')}
        </a>
      
        <div class="flex gap-6 items-center font-bold text-slate-400 dark:text-slate-500">
          <LanguagePicker />
          <a
            href="https://github.com/isanchezv07/open-jp"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-sky-500 transition-colors"
          >
            GitHub
          </a>
          <ThemeToggle client:load />
        </div>
      </div>
    </nav>
		<main class="grow">
			<slot />
		</main>
    <Footer />
    <script>
      import { seedDatabase } from '../lib/db/seed';
      seedDatabase().catch(console.error);
    </script>
	</body>
</html>

<style is:global>
  :root {
    --duo-green: #58cc02;
    --duo-green-border: #46a302;
    --duo-blue: #1cb0f6;
    --duo-blue-border: #1899d6;
    --duo-orange: #ff9600;
    --duo-orange-border: #e68a00;
    --duo-red: #ff4b4b;
    --duo-red-border: #ea2b2b;
    --duo-gray: #afafaf;
    --duo-gray-border: #898989;
  }
  
  body {
    overflow-x: hidden;
  }

  /* 3D Button Style */
  .btn-3d {
    position: relative;
    border-bottom: 4px solid var(--border-color);
    transition: all 0.1s;
  }
  .btn-3d:active {
    border-bottom-width: 0px;
    transform: translateY(4px);
  }

  /* Animations */
  @keyframes bounce-small {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }
  .hover-bounce:hover {
    animation: bounce-small 0.5s infinite;
  }

  /* Custom Scrollbar */
  ::-webkit-scrollbar { width: 10px; }
  ::-webkit-scrollbar-track { background: #f8fafc; }
  ::-webkit-scrollbar-thumb { 
    background: #e2e8f0; 
    border-radius: 5px; 
    border: 2px solid #f8fafc;
  }
  ::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
</style>
